# Azure AI Foundry Configuration
# Copy this file to .env and fill in your values

# Project Endpoint URL (found in Azure AI Foundry portal → Project Settings → Endpoints)
PROJECT_ENDPOINT=https://<your-project-name>.<region>.api.azureml.ms

# Model deployment name (default: gpt-4o)
MODEL_DEPLOYMENT_NAME=gpt-4o

# Optional: Azure Subscription ID (for Labs 2 & 3)
AZURE_SUBSCRIPTION_ID=<your-subscription-id>

# Optional: Resource Group (for Labs 2 & 3)
AZURE_RESOURCE_GROUP=rg-sre-workshop

# ============================================================================
# Lab 1a: Azure Cosmos DB Vector Store
# Run ./scripts/setup-cosmosdb.sh to create these resources automatically
# ============================================================================
COSMOS_ENDPOINT=https://<your-cosmos-account>.documents.azure.com:443/
COSMOS_DATABASE=sre-data
COSMOS_CONTAINER=sre-knowledge

# ============================================================================
# Coding Sandwich: Foundry model + coding engine + Cosmos-backed chat history
# (entities/coding_sandwich — see coding_sandwich_demo.py)
# ============================================================================
# Foundry / Azure OpenAI endpoint hosting the model
AZURE_OPENAI_ENDPOINT=https://<your-foundry-resource>.cognitiveservices.azure.com/
# Coding model deployment (e.g. gpt-5-codex); falls back to MODEL_DEPLOYMENT_NAME
CODING_MODEL_DEPLOYMENT=gpt-4o
# Optional: use a key instead of Entra ID (az login). Leave blank for keyless.
AZURE_OPENAI_API_KEY=
# Where the agent persists chat history (reuses COSMOS_ENDPOINT above)
COSMOS_CHAT_DATABASE=agent-chat
COSMOS_CHAT_CONTAINER=sessions
# Sandbox directory the coding tools are confined to
SANDWICH_WORKSPACE=./sandbox-workspace
